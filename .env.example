# BuildFlow - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# DATABASE (Neon PostgreSQL - serverless)
# Get free at https://neon.tech
# ============================================================
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# AUTH (Auth.js v5 / NextAuth)
# Generate secret: openssl rand -base64 32
# ============================================================
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="same-value-as-AUTH_SECRET"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# ============================================================
# OPENAI (https://platform.openai.com/api-keys)
# Powers AI nodes: text generation, DALL-E renders, vision
# ============================================================
OPENAI_API_KEY="sk-..."

# ============================================================
# STRIPE (https://dashboard.stripe.com/test/apikeys)
# Handles MINI/STARTER/PRO/TEAM subscription billing (INR pricing)
# Create products in Stripe Dashboard → Products → Add Product
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_MINI_PRICE_ID="price_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."
STRIPE_DEFAULT_COUPON_ID=""

# ============================================================
# UPSTASH REDIS (https://upstash.com)
# Powers rate limiting for execution endpoints
# ============================================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
REDIS_URL="redis://localhost:6379"

# ============================================================
# CUBICASA5K ML SERVICE (Floor plan wall detection)
# Self-hosted Flask service running CubiCasa5K segmentation model.
# Used by TR-004 (Floor Plan Analysis) for ML-enhanced wall detection.
# Local dev: http://localhost:5001/analyze
# Production: deploy ~/Projects/buildflow-floorplan-ml/server.py and set
# this to the public URL (e.g. https://ml.your-domain.com/analyze).
# If unset or unreachable, TR-004 falls back to GPT-4o-only analysis.
# ============================================================
ML_SERVICE_URL="http://localhost:5001/analyze"

# ============================================================
# NeoBIM IFC SERVICE (Python, FastAPI, ifcopenshell)
# Source: neobim-ifc-service/ — see neobim-ifc-service/Dockerfile for
# deployment (Railway / Render / Fly compatible).
# When IFC_SERVICE_URL is set and reachable, EX-001 generates IFC4 files
# via this service (richer geometry, proper openings, material layer sets,
# Qto_* base quantities). When unset, unreachable, or returns a non-ready
# probe, EX-001 silently falls back to the built-in TypeScript exporter
# (still produces valid IFC4 — just with less visual richness on complex
# geometry like rebar, curtain walls, and MEP). A Rich/Lean badge on the
# download card in the Export tab tells the user which path ran.
#
# Probe endpoint: GET {IFC_SERVICE_URL}/ready  (public, no auth)
# Export endpoint: POST {IFC_SERVICE_URL}/api/v1/export-ifc  (Bearer auth)
#
# Production: https://buildflow-python-server.up.railway.app
# Local dev:  http://localhost:8000 (cd neobim-ifc-service && uvicorn app.main:app)
#
# IFC_SERVICE_API_KEY must match the value configured on the Python service
# side (Railway env var "API_KEY" or .env). When empty on the service side,
# the service runs in open mode (dev only).
# ============================================================
IFC_SERVICE_URL="https://buildflow-python-server.up.railway.app"
IFC_SERVICE_API_KEY="shared-secret-must-match-railway-api-key"

# Optional richness dial — controls which of the TS exporter's gated
# emitters fire on the TS fallback path. Values: off | arch-only | mep |
# structural | full. Defaults to "off" (current production behaviour —
# no change unless explicitly set). See docs/ifc-phase-1-subplan.md § Track B.
# IFC_RICH_MODE="off"

# ============================================================
# FAL.AI (https://fal.ai/dashboard/keys)
# Powers SAM 3D image-to-3D conversion (GN-007 node)
# ============================================================
FAL_KEY="97d2aeae-8052-4b35-bd5a-425b8f050e7f:41f71bc8f7dd315c1b928653bdd284de"

# ============================================================
# KLING AI (https://klingai.com/global/dev)
# Powers Video Walkthrough Generator (GN-009 node)
# Get AccessKey + SecretKey from Kling developer console
# ============================================================
KLING_ACCESS_KEY="AypYPppMQNnfGPBM8menBTCe4gNbmrTd"
KLING_SECRET_KEY="KGrKPrthQgMFFgar8KFReNeptheA34CA"

# ============================================================
# MESHY (https://docs.meshy.ai)
# Powers Hi-Fi 3D Reconstructor (GN-010 node)
# ============================================================
MESHY_API_KEY="your_meshy_api_key_here"

# ============================================================
# 3D AI STUDIO (https://www.3daistudio.com/Platform/API)
# Powers AI furniture generation for 3D floor plans (Phase 3)
# Studio plan: $29/mo = 3,200 credits. Rapid+PBR = 55 credits/model.
# ============================================================
THREE_D_AI_STUDIO_API_KEY="your_3dai_studio_api_key_here"

# ============================================================
# MESHY.AI (https://www.meshy.ai — Alternative Text-to-3D API)
# Fallback when 3D AI Studio credits are exhausted.
# Sign up for free credits at meshy.ai, get API key from dashboard.
# Uses Meshy-6 model (20 credits/preview).
# ============================================================
MESHY_API_KEY="your_meshy_api_key_here"

# ============================================================
# CLOUDFLARE R2 (https://dash.cloudflare.com → R2)
# Free: 10GB storage, 10M reads/mo, 1M writes/mo
# Stores generated PDFs & XLSX files with 25-day auto-cleanup
# If not configured, files fall back to base64 data URI (still works)
# ============================================================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="buildflow-files"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# Secret for cron cleanup endpoint (generate: openssl rand -base64 32)
CRON_SECRET="your-cron-secret"

# ============================================================
# APP CONFIGURATION
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "true" for local dev without API keys — uses mock execution results
NEXT_PUBLIC_ENABLE_MOCK_EXECUTION="true"

# ============================================================
# RATE LIMITS (optional, defaults shown — all monthly)
# ============================================================
FREE_TIER_EXECUTIONS_PER_MONTH="3"
MINI_TIER_EXECUTIONS_PER_MONTH="10"
STARTER_TIER_EXECUTIONS_PER_MONTH="30"
PRO_TIER_EXECUTIONS_PER_MONTH="100"

# ============================================================
# ADMIN (optional — comma-separated emails that bypass rate limits)
# ============================================================
ADMIN_EMAILS="admin@example.com"

# ============================================================
# ADMIN PANEL SETUP (required for first admin account creation)
# On first launch with no admin accounts, these are used to seed
# a SUPER_ADMIN. After setup, you may remove ADMIN_SETUP_PASSWORD.
# ============================================================
ADMIN_SETUP_USERNAME="your_admin_username"
ADMIN_SETUP_PASSWORD="YourSecurePassword123!"

# ============================================================
# GOOGLE TAG MANAGER (https://tagmanager.google.com)
# Lets marketing deploy tags (GA4, Ads, LinkedIn, etc.) without code changes
# ============================================================
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# ============================================================
# META CONVERSIONS API (https://developers.facebook.com/docs/marketing-api/conversions-api)
# Server-side conversion tracking — bypasses ad blockers for 100% accuracy.
# Generate token: Business Settings → System Users → Generate Token (ads_management)
# ============================================================
META_CAPI_ACCESS_TOKEN=""

# ============================================================
# GOOGLE ANALYTICS 4 (https://analytics.google.com)
# Tracks sessions, page views, audience demographics, conversions
# ============================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ============================================================
# GOOGLE ADS (https://ads.google.com)
# Conversion tracking (AW-…). Shares dataLayer with GA4/GTM.
# Consent Mode v2 gates ad_storage / ad_user_data / ad_personalization.
# ============================================================
NEXT_PUBLIC_GOOGLE_ADS_ID="AW-XXXXXXXXXX"

# ============================================================
# AUTOSEND (https://autosend.com)
# Transactional emails: welcome, verification, payment failed, plan changes
# Hobby plan: $1/month, 3000 emails/month
# ============================================================
AUTOSEND_API_KEY="AS_..."
AUTOSEND_FROM_EMAIL="noreply@yourdomain.com"
AUTOSEND_FROM_NAME="BuildFlow"

# ============================================================
# MICROSOFT CLARITY (https://clarity.microsoft.com)
# Heatmaps, session recordings, and user behavior analytics
# ============================================================
NEXT_PUBLIC_CLARITY_PROJECT_ID="vx5sglywjv"

# Anthropic API (Claude) — Market Intelligence Agent (TR-015) + floor plan analysis
# Must be an API key (sk-ant-api03-...), NOT an OAuth token (sk-ant-oat...).
# Get one from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ============================================================
# SENTRY (https://sentry.io)
# Error tracking and performance monitoring
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================
# RAZORPAY (https://razorpay.com)
# Indian payment gateway: UPI, Google Pay, PhonePe, net banking
# Create plans in Dashboard → Payment Products → Subscriptions → Plans
# ============================================================
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
RAZORPAY_MINI_PLAN_ID="plan_..."
RAZORPAY_STARTER_PLAN_ID="plan_..."
RAZORPAY_PRO_PLAN_ID="plan_..."
RAZORPAY_TEAM_PLAN_ID="plan_..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
SENTRY_AUTH_TOKEN=

# ============================================================
# FLOOR PLAN PIPELINE FLAGS (optional — all default false)
# ============================================================
# PIPELINE_VIP: Visual Intelligence Pipeline (Approach #17).
# When true, VIP runs first for all prompts. Falls through to
# PIPELINE_REF on any failure. Default: false.
PIPELINE_VIP="false"

# PIPELINE_VIP_JOBS: Async VIP job queue (Phase 1.9).
# When true, POST /api/vip-jobs accepts new background VIP jobs.
# Requires QStash env vars below. Default: false.
PIPELINE_VIP_JOBS="false"

# VIP Pipeline Canary Rollout (Phase 1.11b)
# Comma-separated emails that get VIP when PIPELINE_VIP_JOBS=true.
# Case-insensitive. Empty = nobody gets VIP (even with flag on).
VIP_BETA_EMAILS=""

# Platform admin emails that ALWAYS see VIP when flag is on
# (regardless of VIP_BETA_EMAILS). For production testing.
VIP_ADMIN_OVERRIDE_EMAILS=""

# ============================================================
# UPSTASH QSTASH (https://upstash.com/qstash)
# Background job scheduling for VIP pipeline (Phase 1.9+).
# Get credentials from Upstash Console → QStash tab.
# ============================================================
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="your-qstash-signing-key"
QSTASH_NEXT_SIGNING_KEY="your-qstash-next-signing-key"
