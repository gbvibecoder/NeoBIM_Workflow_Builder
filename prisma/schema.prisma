generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String                 @id @default(cuid())
  email         String                 @unique
  name          String?
  image         String?
  emailVerified DateTime?
  // Phone login (production-aligned): phoneNumber is unique because it doubles
  // as a login identifier alongside email. phoneVerified is a timestamp marking
  // when the number was confirmed (null = unverified).
  phoneNumber   String?                @unique
  phoneVerified DateTime?
  password      String?
  role          UserRole               @default(FREE)
  bio           String?
  apiKeys       Json?                  @default("{}")
  stripeCustomerId       String?       @unique
  stripeSubscriptionId   String?       @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  // Razorpay (Indian payment gateway — UPI, Google Pay, PhonePe)
  razorpaySubscriptionId String?       @unique
  razorpayPlanId         String?
  paymentGateway         String?       // "stripe" | "razorpay"
  // Gamification
  xp            Int                    @default(0)
  level         Int                    @default(1)

  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  accounts      Account[]
  achievements  UserAchievement[]
  publications    CommunityPublication[]
  communityVideos CommunityVideo[]
  executions      Execution[]
  reviews         Review[]
  sessions        Session[]
  clones          WorkflowClone[]
  feedbacks       Feedback[]
  quantityCorrections QuantityCorrection[]
  workflows       Workflow[]
  referralsSent     Referral[]  @relation("ReferralsSent")
  referralsReceived Referral[]  @relation("ReferralReceived")
  supportConversations SupportConversation[]
  liveChats         LiveChatConversation[] @relation("UserLiveChats")
  videoShareLinks   VideoShareLink[]
  videoLikes        CommunityVideoLike[]
  survey            UserSurvey?
  vipGenerations    VipGeneration[]
  vipJobs           VipJob[]

  @@map("users")
}

model UserSurvey {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  discoverySource  String?
  discoveryOther   String?
  profession       String?
  professionOther  String?
  teamSize         String?
  pricingAction    String?
  completedAt      DateTime?
  skippedAt        DateTime?
  skippedAtScene   Int?
  // ── Attribution — first-touch only, never overwritten on auto-save ──
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmTerm          String?
  utmContent       String?
  referrer         String?
  country          String?
  city             String?
  deviceType       String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("user_surveys")
  @@index([userId])
  @@index([completedAt])
  @@index([createdAt])
  @@index([utmSource])
  @@index([country])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workflow {
  id           String                 @id @default(cuid())
  ownerId      String
  name         String
  description  String?
  tags         String[]
  tileGraph    Json                   @default("{\"edges\": [], \"nodes\": []}")
  version      Int                    @default(1)
  isPublished  Boolean                @default(false)
  isTemplate   Boolean                @default(false)
  thumbnail    String?
  category     String?
  complexity   WorkflowComplexity     @default(SIMPLE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  // Soft-delete marker. When set, the workflow is hidden from the owning
  // user's "My Workflows" view, but its row + all related Executions and
  // Artifact metadata are intentionally preserved so admin/audit pages
  // continue to show full historical activity. R2 storage is still wiped
  // by the bulk-delete endpoint when this is set.
  deletedAt    DateTime?
  publications CommunityPublication[]
  executions   Execution[]
  tiles        TileInstance[]
  clones       WorkflowClone[]
  versions     WorkflowVersion[]
  owner        User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([isTemplate])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("workflows")
}

model WorkflowVersion {
  id           String   @id @default(cuid())
  workflowId   String
  version      Int
  name         String
  description  String?
  tileGraph    Json
  createdAt    DateTime @default(now())
  createdBy    String
  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
  @@map("workflow_versions_history")
}

model TileInstance {
  id            String     @id @default(cuid())
  workflowId    String
  tileType      String
  positionX     Float      @default(0)
  positionY     Float      @default(0)
  configuration Json       @default("{}")
  createdAt     DateTime   @default(now())
  artifacts     Artifact[]
  workflow      Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("tile_instances")
}

model Execution {
  id           String          @id @default(cuid())
  workflowId   String
  userId       String
  status       ExecutionStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  tileResults  Json            @default("[]")
  errorMessage String?
  // Per-execution UI/state metadata (e.g. quantityOverrides for Task 2,
  // videoGenProgress for Task 3). Nullable JSON column written via
  // PATCH /api/executions/[id]/metadata. Stays null for executions
  // created before this column existed.
  metadata     Json?
  createdAt    DateTime        @default(now())
  artifacts    Artifact[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow     Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@map("executions")
}

model Artifact {
  id             String       @id @default(cuid())
  executionId    String
  tileInstanceId String
  type           ArtifactType
  dataUri        String?
  data           Json?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  execution      Execution    @relation(fields: [executionId], references: [id], onDelete: Cascade)
  tileInstance   TileInstance @relation(fields: [tileInstanceId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([tileInstanceId])
  @@map("artifacts")
}

model CommunityPublication {
  id           String   @id @default(cuid())
  workflowId   String
  authorId     String
  title        String
  description  String
  tags         String[]
  thumbnailUri String?
  ratingAvg    Float    @default(0)
  cloneCount   Int      @default(0)
  version      Int      @default(1)
  isFeatured   Boolean  @default(false)
  isReported   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  reviews      Review[]

  @@index([authorId])
  @@index([workflowId])
  @@index([ratingAvg])
  @@index([cloneCount])
  @@map("community_publications")
}

model Review {
  id            String               @id @default(cuid())
  publicationId String
  userId        String
  stars         Int
  comment       String?
  createdAt     DateTime             @default(now())
  publication   CommunityPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([publicationId, userId])
  @@map("reviews")
}

model WorkflowClone {
  id         String   @id @default(cuid())
  workflowId String
  userId     String
  sourceId   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([userId])
  @@map("workflow_clones")
}

enum UserRole {
  FREE
  MINI
  STARTER
  PRO
  TEAM_ADMIN
  PLATFORM_ADMIN
}

enum WorkflowComplexity {
  SIMPLE
  INTERMEDIATE
  ADVANCED
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ArtifactType {
  TEXT
  JSON
  IMAGE
  THREE_D
  FILE
  TABLE
  KPI
  VIDEO
}

// ─── Referral Program ─────────────────────────────────────────────

model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referredId  String?
  code        String    @unique
  status      String    @default("pending") // pending, completed
  rewardGiven Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  referrer    User      @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referred    User?     @relation("ReferralReceived", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([code])
  @@map("referrals")
}

// ─── Community Videos ──────────────────────────────────────────────

model CommunityVideo {
  id           String   @id @default(cuid())
  authorId     String
  title        String
  description  String?
  category     String   @default("General")
  videoUrl     String
  duration     String?
  views        Int      @default(0)
  likes        Int      @default(0)
  isApproved   Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likedBy      CommunityVideoLike[]

  @@index([authorId])
  @@index([createdAt])
  @@map("community_videos")
}

// Per-user like tracking for community videos. Joins users to videos they've
// liked so the like API can be idempotent and the GET /community-videos
// endpoint can return `isLikedByMe` per video. The `likes Int` counter on
// CommunityVideo above is kept as a denormalized display value, maintained
// transactionally alongside this table.
model CommunityVideoLike {
  id        String         @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     CommunityVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
  @@map("community_video_likes")
}

// ─── Gamification ──────────────────────────────────────────────────

model UserAchievement {
  id        String   @id @default(cuid())
  userId    String
  action    String
  xpAwarded Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action])
  @@index([userId])
  @@map("user_achievements")
}

model FlashEventCompletion {
  id        String   @id @default(cuid())
  userId    String
  eventKey  String
  createdAt DateTime @default(now())

  @@unique([userId, eventKey])
  @@index([userId])
  @@map("flash_event_completions")
}

// ─── Beta Feedback ────────────────────────────────────────────────

model Feedback {
  id            String         @id @default(cuid())
  userId        String
  type          FeedbackType
  title         String
  description   String
  category      String?
  screenshotUrl String?
  status        FeedbackStatus @default(NEW)
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("feedback")
}

enum FeedbackType {
  BUG
  FEATURE
  SUGGESTION
}

enum FeedbackStatus {
  NEW
  REVIEWING
  PLANNED
  IN_PROGRESS
  DONE
  DECLINED
}

// ─── Admin Dashboard ─────────────────────────────────────────────

model AdminAccount {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  displayName  String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  sessionToken String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AdminAuditLog[]

  @@map("admin_accounts")
}

model AdminAuditLog {
  id         String        @id @default(cuid())
  adminId    String?
  admin      AdminAccount? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String?
  details    Json          @default("{}")
  ipAddress  String?
  createdAt  DateTime      @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

// ─── AI Roadmap Agent ────────────────────────────────────────────────

model AiRoadmap {
  id               String           @id @default(cuid())
  weekOf           DateTime
  summary          String
  riskFlags        String[]
  quickWins        String[]
  feedbackAnalysis Json             @default("{}")
  metricsSnapshot  Json             @default("{}")
  generatedBy      String?
  createdAt        DateTime         @default(now())
  tasks            AiRoadmapTask[]

  @@index([weekOf])
  @@index([createdAt])
  @@map("ai_roadmaps")
}

model AiRoadmapTask {
  id                String    @id @default(cuid())
  roadmapId         String
  title             String
  description       String
  priority          String    // P0, P1, P2, P3
  effort            String    // XS, S, M, L, XL
  category          String    // bug-fix, feature, improvement, infra, dx, ux
  status            String    @default("todo") // todo, in-progress, done, deferred, dropped
  reasoning         String?
  linkedFeedbackIds String[]
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  roadmap           AiRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@index([status])
  @@map("ai_roadmap_tasks")
}

// QS Feedback Loop — stores quantity corrections from professional QS users
// Used to calibrate the IFC parser over time. Each correction improves future estimates.
model QuantityCorrection {
  id              String   @id @default(cuid())
  userId          String
  workflowId      String?
  elementType     String   // "IfcWall", "IfcSlab", "IfcColumn", etc.
  buildingType    String   // "commercial", "residential", "wellness", etc.
  city            String
  state           String
  extractedQty    Float    // What the parser extracted
  correctedQty    Float    // What the QS corrected to
  correctionRatio Float    // corrected / extracted
  unit            String   // "m²", "m³", "Rmt", "EA"
  notes           String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([elementType, buildingType, state])
  @@index([userId])
  @@index([createdAt])
  @@map("quantity_corrections")
}

// BOQ run analytics — every successful BOQ improves future estimates
model BOQAnalytics {
  id              String   @id @default(cuid())
  city            String
  state           String
  buildingType    String
  gfa             Float
  floors          Int
  costPerM2       Float
  materialRatio   Float
  laborRatio      Float
  masonRate       Float
  steelRate       Float
  cementRate      Float
  ifcQuality      String
  provisionalPct  Float
  createdAt       DateTime @default(now())

  @@index([state, buildingType])
  @@index([createdAt])
  @@map("boq_analytics")
}

// ─── AI Support Chat System ──────────────────────────────────────

enum SupportStatus {
  ACTIVE
  ESCALATED
  ADMIN_REPLIED
  RESOLVED
  CLOSED
}

enum MessageRole {
  USER
  AI
  ADMIN
  SYSTEM
}

enum SupportCategory {
  GENERAL
  WORKFLOW_HELP
  NODE_EXECUTION
  BILLING
  BUG_REPORT
  FEATURE_REQUEST
  IFC_PARSING
  COST_ESTIMATION
  THREE_D_GENERATION
  ACCOUNT
  TECHNICAL
}

model SupportConversation {
  id             String            @id @default(cuid())
  userId         String
  status         SupportStatus     @default(ACTIVE)
  category       SupportCategory   @default(GENERAL)
  subject        String?
  summary        String?
  priority       Int               @default(0)
  escalatedAt    DateTime?
  resolvedAt     DateTime?
  resolvedBy     String?
  assignedTo     String?
  satisfaction   Int?
  feedbackNote   String?
  pageContext    String?
  userPlan       String?
  messageCount   Int               @default(0)
  lastMessageAt  DateTime          @default(now())
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
  @@index([lastMessageAt])
  @@index([assignedTo])
  @@map("support_conversations")
}

model SupportMessage {
  id              String          @id @default(cuid())
  conversationId  String
  role            MessageRole
  content         String
  metadata        Json            @default("{}")
  isInternal      Boolean         @default(false)
  createdAt       DateTime        @default(now())

  conversation    SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@map("support_messages")
}

model SupportQuickReply {
  id          String          @id @default(cuid())
  title       String
  content     String
  category    SupportCategory @default(GENERAL)
  usageCount  Int             @default(0)
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@map("support_quick_replies")
}

// ─── Live Chat (human-to-human support) ─────────────────────────────────────

enum LiveChatStatus {
  WAITING
  ACTIVE
  CLOSED
}

enum LiveChatRole {
  USER
  ADMIN
}

model LiveChatConversation {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation("UserLiveChats", fields: [userId], references: [id], onDelete: Cascade)
  status           LiveChatStatus @default(WAITING)
  lastMessageAt    DateTime       @default(now())
  lastAdminReplyAt DateTime?
  repliedByAdminId String?
  repliedByName    String?
  closedByAdminId  String?
  closedAt         DateTime?
  pageContext      String?
  userPlan         String?
  messageCount     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  messages         LiveChatMessage[]

  @@index([userId])
  @@index([status, lastMessageAt])
  @@index([lastMessageAt(sort: Desc)])
  @@map("live_chat_conversations")
}

model LiveChatMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   LiveChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderRole     LiveChatRole
  senderName     String?
  content        String                @db.VarChar(3000)
  createdAt      DateTime              @default(now())

  @@index([conversationId, createdAt])
  @@map("live_chat_messages")
}

// ─── Video Share Links ──────────────────────────────────────────────────────
// Public, slug-addressed share links for generated walkthrough videos.
// Created via POST /api/share/video and consumed by app/share/[slug]/page.tsx.
// View count is incremented (best-effort) on each public page load.
model VideoShareLink {
  id          String    @id @default(cuid())
  slug        String    @unique
  videoUrl    String
  title       String?
  expiresAt   DateTime?
  viewCount   Int       @default(0)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([createdById])
  @@index([createdAt])
  @@map("video_share_links")
}

/// Persistent material price cache — survives Redis TTL expiry.
/// Written after every successful TR-015 market intelligence fetch.
/// Queried by the price-fallback-chain when Redis cache misses.
/// Enables cross-user learning: once ANY user fetches prices for Pune,
/// ALL subsequent Pune BOQs benefit even if their own TR-015 fails.
model MaterialPriceCache {
  id              String   @id @default(cuid())
  city            String                         // e.g. "Pune"
  state           String                         // e.g. "Maharashtra"
  materialCode    String                         // e.g. "steel_per_tonne", "cement_per_bag", "labor_mason"
  price           Float                          // numeric price in INR
  unit            String                         // e.g. "₹/tonne", "₹/bag", "₹/day"
  source          String                         // e.g. "market_intelligence", "user_correction"
  confidence      String                         // "HIGH", "MEDIUM", "LOW"
  fetchedAt       DateTime @default(now())       // when price was fetched
  expiresAt       DateTime                       // fetchedAt + 30 days

  // ── Provenance fields (Sprint 1 addition) ───────────────────────────────
  sourceUrl       String?                        // URL where price was found
  rawResponse     Json?                          // full AI/scraper response for audit
  confidenceScore Float?                         // 0-100 numeric confidence score
  method          String?                        // AI_SEARCH | PWD_TENDER | DEALER_PORTAL | CPWD_STATIC | USER_CORRECTION | INTERPOLATED

  @@index([city, materialCode, fetchedAt])
  @@index([state, materialCode, fetchedAt])
  @@index([materialCode, fetchedAt])
  @@map("material_price_cache")
}

// ─── VIP Pipeline Observability ─────────────────────────────────

enum VipGenerationStatus {
  RUNNING
  SUCCESS
  FALL_THROUGH
  FAILED
}

model VipGeneration {
  id                String              @id @default(cuid())
  userId            String
  requestId         String              @unique
  prompt            String
  status            VipGenerationStatus @default(RUNNING)
  pipelineUsed      String?
  stageTimings      Json?
  stageCosts        Json?
  stageErrors       Json?
  finalScore        Int?
  totalDurationMs   Int?
  totalCostUsd      Float?
  fallThroughReason String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("vip_generations")
}

// ─── VIP Background Jobs ────────────────────────────────────────

enum VipJobStatus {
  QUEUED
  RUNNING
  AWAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

model VipJob {
  id             String       @id @default(cuid())
  userId         String
  requestId      String       @unique
  prompt         String
  status         VipJobStatus @default(QUEUED)
  progress       Int          @default(0)
  currentStage   String?
  resultProject  Json?
  errorMessage   String?
  costUsd        Float        @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  // Phase 2.3 Workstream C: image approval gate.
  // When the worker completes Stage 2, it stores the stage1+stage2
  // outputs here as JSON, sets status=AWAITING_APPROVAL, and waits
  // for the user to click Approve (→ /api/vip-jobs/[id]/approve) or
  // Regenerate image (→ /api/vip-jobs/[id]/regenerate-image). A
  // second QStash message then picks up stages 3-7.
  pausedAt          DateTime?
  pausedStage       Int?
  intermediateImage String?   // base64 of the Stage 2 GPT image
  intermediateBrief Json?     // full stage 1 output (brief + imagePrompts)
  userApproval      String?   // 'pending' | 'approved' | 'regenerating'
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("vip_jobs")
}
